{
  "name": "sy-github-notifier",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon --watch \"src/**\" --ext \"ts,json\" --ignore \"src/**/*.spec.ts\" --exec \"ts-node src/main.ts\"",
    "build": "tsc --project tsconfig.prod.json && tsc-alias -p tsconfig.prod.json",
    "start": "node .build/main.js",
    "eslint:check": "eslint .",
    "prettier:check": "prettier -c \"./**/*.ts\"",
    "lint": "pnpm run eslint:check && pnpm run prettier:check",
    "vitest:unit": "vitest --config=./vitest.unit.config.ts",
    "vitest:integration": "vitest --config=./vitest.int.config.ts",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "migrate": "node .build/shared/db/migrate.js",
    "prepare": "husky",
    "proto:gen": "proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --grpcLib=@grpc/grpc-js --outDir=src/grpc/proto-types src/grpc/subscription.proto",
    "expose:env": "NODE_ENV=${NODE_ENV:-test} dotenv-flow -p profiles",
    "docker-compose": "pnpm expose:env -- docker compose",
    "docker:up:local": "pnpm run docker-compose --profile local up -d",
    "docker:down": "pnpm run docker-compose --profile local down"
  },
  "engines": {
    "node": "22",
    "pnpm": "10"
  },
  "_moduleAliases": {
    "@src": "dist"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "axios": "^1.15.0",
    "bottleneck": "^2.19.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv-expand": "^12.0.3",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "ms": "^2.1.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.24",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/find": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/google-protobuf": "^3.15.12",
    "@types/jsonfile": "^6.1.4",
    "@types/module-alias": "^2.0.4",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@vitest/coverage-v8": "^4.1.4",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "delay-cli": "^3.0.0",
    "dotenv-flow-cli": "^1.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "find": "^0.3.0",
    "fs-extra": "^11.3.4",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
